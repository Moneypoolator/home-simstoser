<Window x:Class="S3StorageClient.Views.CreateKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Access Key"
        Width="400"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select User:" FontSize="13" Margin="0,0,0,5" />
        <ComboBox x:Name="cmbUser" Grid.Row="1"
                  Height="30"
                  FontSize="13"
                  DisplayMemberPath="Username"
                  SelectedValuePath="Username" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Create"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="30"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click" />
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="30"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>