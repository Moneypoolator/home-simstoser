<UserControl x:Class="S3StorageClient.Views.KeysPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Create Key" Style="{StaticResource PrimaryButtonStyle}" Width="100" Height="30" Margin="0,0,5,0" Click="BtnCreate_Click" />
                <Button Content="Activate" Style="{StaticResource PrimaryButtonStyle}" Width="90" Height="30" Margin="0,0,5,0" Click="BtnActivate_Click" />
                <Button Content="Deactivate" Style="{StaticResource PrimaryButtonStyle}" Width="90" Height="30" Margin="0,0,5,0" Click="BtnDeactivate_Click" />
                <Button Content="Delete" Style="{StaticResource PrimaryButtonStyle}" Width="90" Height="30" Margin="0,0,5,0" Click="BtnDelete_Click" />
                <Button Content="Refresh" Style="{StaticResource PrimaryButtonStyle}" Width="90" Height="30" Click="BtnRefresh_Click" />
            </StackPanel>
        </Border>

        <!-- Keys list -->
        <ListView x:Name="keysList" Grid.Row="1"
                 BorderBrush="#E5E7EB"
                 BorderThickness="1"
                 SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Access Key ID" Width="250" DisplayMemberBinding="{Binding AccessKeyId}" />
                    <GridViewColumn Header="User" Width="120" DisplayMemberBinding="{Binding UserName}" />
                    <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                    <GridViewColumn Header="Created" Width="150" DisplayMemberBinding="{Binding CreatedAt}" />
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status bar -->
        <TextBlock x:Name="lblStatus" Grid.Row="2" Style="{StaticResource StatusBarStyle}" />
    </Grid>
</UserControl>