<Window x:Class="S3StorageClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S3 Storage - Login"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid>
        <Border Background="White"
                Width="380" Height="460"
                CornerRadius="8"
                Margin="20,30">
            <StackPanel Margin="30,20,30,20">
                <!-- Title -->
                <TextBlock Text="S3 Storage"
                         FontSize="24" FontWeight="Bold"
                         Foreground="#2563EB"
                         TextAlignment="Center"
                         Margin="0,10,0,0" />
                <TextBlock Text="Sign in to access the storage"
                         FontSize="11"
                         Foreground="#6B7280"
                         TextAlignment="Center"
                         Margin="0,5,0,20" />

                <!-- Server URL -->
                <TextBlock Text="Server URL"
                         FontSize="12" FontWeight="Bold"
                         Foreground="#374151"
                         Margin="0,0,0,4" />
                <TextBox x:Name="txtServerUrl"
                        FontSize="13"
                        Padding="8,6"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,0,15"
                        KeyDown="TxtServerUrl_KeyDown" />

                <!-- Username -->
                <TextBlock Text="Username"
                         FontSize="12" FontWeight="Bold"
                         Foreground="#374151"
                         Margin="0,0,0,4" />
                <TextBox x:Name="txtUsername"
                        FontSize="13"
                        Padding="8,6"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        Margin="0,0,0,15"
                        KeyDown="TxtUsername_KeyDown" />

                <!-- Password -->
                <TextBlock Text="Password"
                         FontSize="12" FontWeight="Bold"
                         Foreground="#374151"
                         Margin="0,0,0,4" />
                <PasswordBox x:Name="txtPassword"
                            FontSize="13"
                            Padding="8,6"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Margin="0,0,0,15"
                            KeyDown="TxtPassword_KeyDown" />

                <!-- Error message -->
                <TextBlock x:Name="lblError"
                         Foreground="#DC2626"
                         FontSize="12"
                         TextAlignment="Center"
                         Visibility="Collapsed"
                         Margin="0,0,0,10"
                         TextWrapping="Wrap" />

                <!-- Login button -->
                <Button x:Name="btnLogin"
                       Content="Sign In"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Height="40"
                       FontSize="14"
                       Margin="0,5,0,0"
                       Click="BtnLogin_Click" />

                <!-- Test credentials info -->
                <TextBlock Text="Test credentials:&#x0a;username: admin&#x0a;password: admin123"
                         FontSize="11"
                         Foreground="#9CA3AF"
                         TextAlignment="Center"
                         Margin="0,15,0,0"
                         LineHeight="16" />
            </StackPanel>
        </Border>
    </Grid>
</Window>