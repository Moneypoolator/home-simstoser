<UserControl x:Class="S3StorageClient.Views.MonitoringPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Monitoring" FontSize="20" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="Server status and performance metrics" FontSize="10" Foreground="#6B7280" />
                </StackPanel>
                <CheckBox x:Name="chkAutoRefresh" Grid.Column="2" Content="Auto-refresh (10s)"
                          VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="True"
                          Checked="ChkAutoRefresh_Checked" Unchecked="ChkAutoRefresh_Unchecked" />
                <Button Grid.Column="3" Content="Refresh"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="90" Height="30"
                        Click="BtnRefresh_Click" />
            </Grid>
        </Border>

        <!-- Content (scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,10">
                <!-- Row 1: Status cards -->
                <WrapPanel Margin="0,0,0,10">
                    <!-- Server Status card -->
                    <Border x:Name="statusCard" Style="{StaticResource SectionCardStyle}" Width="250" Height="140" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Server Status" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Current system state" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="lblStatusIcon" FontSize="24" Text="?" VerticalAlignment="Center" />
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="lblStatusText" FontSize="10" FontWeight="Bold" Foreground="#111827" />
                                    <TextBlock x:Name="lblStatusMessage" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblLastCheck" FontSize="8" Foreground="#9CA3AF" FontStyle="Italic" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Uptime card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="250" Height="140" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Uptime" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Since server start" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <TextBlock x:Name="lblUptimeValue" Grid.Row="2" FontSize="24" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" Text="0m" />
                        </Grid>
                    </Border>

                    <!-- Connections card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="250" Height="140" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Active Connections" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Current connections" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <TextBlock x:Name="lblConnectionsValue" Grid.Row="2" FontSize="24" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" Text="0" />
                        </Grid>
                    </Border>
                </WrapPanel>

                <!-- Row 2: Request stats + Latency -->
                <WrapPanel Margin="0,0,0,10">
                    <!-- Request Statistics card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="380" Height="200" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Request Statistics" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Total processed requests" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <StackPanel Grid.Row="2" Margin="0,5,0,0">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total Requests" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblTotalRequests" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Client Errors (4xx)" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblClientErrors" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Server Errors (5xx)" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblServerErrors" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Successful Requests" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblSuccessRequests" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Latency card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="380" Height="200" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Latency (ms)" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Response time percentiles" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <StackPanel Grid.Row="2" Margin="0,5,0,0">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="P50 (median)" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblP50" Grid.Column="1" Text="0.00 ms" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="P90" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblP90" Grid.Column="1" Text="0.00 ms" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="P95" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblP95" Grid.Column="1" Text="0.00 ms" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="P99" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblP99" Grid.Column="1" Text="0.00 ms" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </WrapPanel>

                <!-- Row 3: Rate limiting + Memory -->
                <WrapPanel Margin="0,0,0,10">
                    <!-- Rate Limiting card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="380" Height="200" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Rate Limiting" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="DDoS protection and limits" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <StackPanel Grid.Row="2" Margin="0,5,0,0">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Active Bans" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblActiveBans" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total Banned" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblTotalBanned" Grid.Column="1" Text="0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Requests/Minute" FontSize="9" Foreground="#4B5563" />
                                    <TextBlock x:Name="lblRequestsPerMinute" Grid.Column="1" Text="0.0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Memory Usage card -->
                    <Border Style="{StaticResource SectionCardStyle}" Width="380" Height="200" Margin="0,0,10,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Memory Usage" FontWeight="Bold" FontSize="10" Foreground="#111827" />
                            <TextBlock Grid.Row="1" Text="Server memory consumption" FontSize="8" Foreground="#6B7280" Margin="0,0,0,5" />
                            <TextBlock x:Name="lblMemoryValue" Grid.Row="2" FontSize="10" FontWeight="Bold" Foreground="#111827" Margin="0,5,0,5" Text="0 B" />
                            <ProgressBar x:Name="memoryBar" Grid.Row="3" Height="20" Minimum="0" Maximum="100" Value="0"
                                         Foreground="#4F46E5" Background="#E5E7EB" />
                        </Grid>
                    </Border>
                </WrapPanel>

                <!-- Row 4: Request Methods Distribution -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Request Methods Distribution" FontWeight="Bold" FontSize="12" Foreground="#111827" />
                        <TextBlock Grid.Row="1" Text="Request count by HTTP method" FontSize="9" Foreground="#6B7280" Margin="0,0,0,10" />
                        <WrapPanel x:Name="methodsPanel" Grid.Row="2" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <TextBlock x:Name="lblStatus" Grid.Row="2" Style="{StaticResource StatusBarStyle}" />
    </Grid>
</UserControl>