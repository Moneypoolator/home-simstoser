<Window x:Class="S3StorageClient.Views.MultipartUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multipart Upload"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File selection -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Select File:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtFilename" Grid.Column="0"
                        IsReadOnly="True"
                        Padding="8,6"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1" />
                <Button x:Name="btnSelectFile" Grid.Column="1" Content="Browse..." Margin="5,0,0,0"
                        Height="30" Width="100"
                        Click="BtnSelectFile_Click" />
            </Grid>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <ProgressBar x:Name="progressBar" Height="25" Minimum="0" Maximum="100" />
            <TextBlock x:Name="lblProgress" Text="Ready" FontSize="12" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Parts list -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Upload Parts:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />
            <ListView x:Name="partsList" Height="200"
                     BorderBrush="#E5E7EB"
                     BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Part" Width="80" DisplayMemberBinding="{Binding PartNumber}" />
                        <GridViewColumn Header="Size" Width="120" DisplayMemberBinding="{Binding PartSize}" />
                        <GridViewColumn Header="Status" Width="150" DisplayMemberBinding="{Binding Status}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="btnStart" Content="Start Upload"
                   Style="{StaticResource PrimaryButtonStyle}"
                   Width="130" Height="35"
                   IsEnabled="False"
                   Margin="0,0,10,0"
                   Click="BtnStart_Click" />
            <Button x:Name="btnAbort" Content="Abort"
                   Style="{StaticResource DangerButtonStyle}"
                   Width="100" Height="35"
                   IsEnabled="False"
                   Margin="0,0,10,0"
                   Click="BtnAbort_Click" />
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="lblStatus" Grid.Row="4"
                 FontSize="11" FontStyle="Italic"
                 Foreground="#6B7280"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,5" />
    </Grid>
</Window>