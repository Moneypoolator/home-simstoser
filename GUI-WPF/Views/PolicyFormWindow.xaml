<Window x:Class="S3StorageClient.Views.PolicyFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Policy"
        Width="620"
        Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Policy Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Policy Name *:" FontSize="13" Margin="0,0,0,3" />
            <TextBox x:Name="txtName" Height="30" FontSize="13" BorderBrush="#D1D5DB" />
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Description:" FontSize="13" Margin="0,0,0,3" />
            <TextBox x:Name="txtDescription" Height="60" FontSize="13"
                     BorderBrush="#D1D5DB"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <!-- Permissions header -->
        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Permissions:" FontSize="13" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="+ Add Permission"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="130" Height="25"
                    HorizontalAlignment="Left"
                    Margin="10,0,0,0"
                    Click="BtnAddPermission_Click" />
        </Grid>

        <!-- Permissions list (scrollable) -->
        <ScrollViewer Grid.Row="3" Margin="0,0,0,10"
                      VerticalScrollBarVisibility="Auto"
                      BorderBrush="#E5E7EB"
                      BorderThickness="1"
                      Background="#F9FAFB">
            <StackPanel x:Name="permissionsStack" Margin="5" />
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button x:Name="btnSave" Content="Create"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="120" Height="30"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click" />
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="30"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>