<UserControl x:Class="S3StorageClient.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="#111827" />
                <TextBlock Text="Configure your storage client" FontSize="10" Foreground="#6B7280" />
            </StackPanel>
        </Border>

        <!-- Content (scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <!-- General Settings -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="General Settings" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Margin="15,20,15,15">
                            <TextBlock Text="Server URL:" FontSize="9" Foreground="#4B5563" />
                            <TextBox x:Name="txtServerUrl" Height="30" FontSize="10" Margin="0,5,0,3" BorderBrush="#D1D5DB" />
                            <TextBlock Text="The base URL of the S3-compatible storage server" FontSize="8" FontStyle="Italic" Foreground="#9CA3AF" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Appearance -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Margin="15,20,15,15">
                            <TextBlock Text="Theme:" FontSize="9" Foreground="#4B5563" />
                            <ComboBox x:Name="cmbTheme" Height="30" Width="200" HorizontalAlignment="Left" Margin="0,5,0,0" FontSize="10">
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Notifications" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Margin="15,20,15,15">
                            <CheckBox x:Name="chkNotifications" Content="Show notifications" FontSize="10" IsChecked="True" />
                            <TextBlock Text="Pop-up notifications for actions" FontSize="8" FontStyle="Italic" Foreground="#9CA3AF" Margin="20,2,0,10" />
                            <CheckBox x:Name="chkAutoRefresh" Content="Auto-refresh" FontSize="10" IsChecked="True" />
                            <TextBlock Text="Automatically refresh file lists" FontSize="8" FontStyle="Italic" Foreground="#9CA3AF" Margin="20,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Account -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Account" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Margin="15,20,15,15">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Username:" FontSize="9" Foreground="#4B5563" VerticalAlignment="Center" />
                                <TextBlock x:Name="lblUsername" Grid.Column="1" FontSize="10" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="User ID:" FontSize="9" Foreground="#4B5563" VerticalAlignment="Center" />
                                <TextBlock x:Name="lblUserId" Grid.Column="1" FontSize="10" Foreground="#111827" VerticalAlignment="Center" />
                            </Grid>
                            <Button Content="Logout"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Width="120" Height="35"
                                    HorizontalAlignment="Left"
                                    Click="BtnLogout_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Actions" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="15,20,15,15">
                            <Button Content="Save Settings"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="130" Height="35"
                                    Margin="0,0,10,0"
                                    Click="BtnSave_Click" />
                            <Button Content="Reset Settings"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="130" Height="35"
                                    Click="BtnReset_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- System Information -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="System Information" FontSize="12" FontWeight="Bold" Foreground="#111827" Margin="15,12,0,0" />
                        <StackPanel Margin="15,20,15,15">
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Version" FontSize="9" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="1.0.0" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Build" FontSize="9" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="2026.03.20" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Platform" FontSize="9" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text=".NET 8.0 WPF" FontSize="9" FontWeight="Bold" Foreground="#111827" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <TextBlock x:Name="lblStatus" Grid.Row="2" Style="{StaticResource StatusBarStyle}" />
    </Grid>
</UserControl>