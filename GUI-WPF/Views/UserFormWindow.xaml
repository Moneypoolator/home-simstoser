<Window x:Class="S3StorageClient.Views.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create User"
        Width="400" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Username -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Username:" FontSize="12" Margin="0,0,0,4" />
            <TextBox x:Name="txtUsername" Padding="8,6" BorderBrush="#D1D5DB" BorderThickness="1" />
        </StackPanel>

        <!-- Email -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Email:" FontSize="12" Margin="0,0,0,4" />
            <TextBox x:Name="txtEmail" Padding="8,6" BorderBrush="#D1D5DB" BorderThickness="1" />
        </StackPanel>

        <!-- Role -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Role:" FontSize="12" Margin="0,0,0,4" />
            <ComboBox x:Name="cmbRole" Padding="6,4" BorderBrush="#D1D5DB" BorderThickness="1">
                <ComboBoxItem Content="ADMIN" />
                <ComboBoxItem Content="MANAGER" />
                <ComboBoxItem Content="CONTRIBUTOR" />
                <ComboBoxItem Content="VIEWER" IsSelected="True" />
                <ComboBoxItem Content="GUEST" />
            </ComboBox>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Create" Style="{StaticResource PrimaryButtonStyle}" Width="100" Height="30" Margin="0,0,10,0" Click="BtnSave_Click" />
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Width="100" Height="30" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>