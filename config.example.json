{
  "address": "0.0.0.0",
  "port": 9000,
  "storage_path": "./storage",
  "keys_file": "./access_keys.csv",
  "users_file": "./users.csv",
  "enable_auth": true,
  "enable_ssl": false,
  "use_letsencrypt": false,
  "letsencrypt_dir": "",
  "ssl": null,
  "cors": {
    "allowed_origins": ["*"],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD"],
    "allowed_headers": ["Content-Type", "Authorization", "X-Amz-Date", "X-Amz-Security-Token", "X-Requested-With", "X-Access-Key"],
    "exposed_headers": ["ETag", "X-File-Size", "X-Upload-Id"],
    "allow_credentials": false,
    "max_age": 86400
  },
  "upload_limits": {
    "max_file_size": 5368709120,
    "max_part_size": 104857600,
    "max_parts_per_upload": 10000,
    "max_temp_storage_total": 21474836480
  },
  "keep_alive": {
    "enabled": true,
    "timeout_seconds": 15,
    "max_requests": 100
  },
  "rate_limiter": {
    "max_requests_per_minute": 60,
    "max_requests_per_hour": 3600,
    "max_burst_size": 10,
    "max_connections_per_ip": 10,
    "max_connection_rate": 100,
    "max_request_size": 104857600,
    "max_upload_size": 1073741824,
    "window_seconds": 60,
    "ban_duration": 300,
    "enable_ddos_protection": true,
    "ddos_threshold": 100,
    "ddos_window": 10
  },
  "logging": {
    "log_level": 0,
    "log_dir": ""
  }
}